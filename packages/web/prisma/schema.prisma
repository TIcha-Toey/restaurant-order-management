generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id              String   @id @default(cuid())
  orderId         String   @unique
  channel         String
  externalOrderId String?
  items           Json
  totalAmount     Float
  totalCost       Float
  customerName    String?
  customerPhone   String?
  deliveryAddress String?
  orderTime       BigInt
  status          String   @default("received")
  priorityScore   Float    @default(0)
  notes           String?
  enteredBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transitions OrderTransition?
  income      IncomeRecord?

  @@index([channel])
  @@index([status])
}

model OrderTransition {
  id            String  @id @default(cuid())
  orderId       String  @unique
  receivedAt    BigInt?   // สร้างออเดอร์
  confirmedAt   BigInt?   // ยืนยันออเดอร์
  preparingAt   BigInt?   // เริ่มทำ
  readyAt       BigInt?   // เสร็จแล้ว
  pickedUpAt    BigInt?   // มารับ
  deliveredAt   BigInt?   // ส่งมอบสำเร็จ
  cancelledAt   BigInt?   // ยกเลิก
  cancelReason  String?
  lastActor     String?   // พนักงานที่อัปเดตล่าสุด

  order Order @relation(fields: [orderId], references: [orderId])
}

model IncomeRecord {
  id               String  @id @default(cuid())
  recordId         String  @unique
  source           String  // "order" | "manual"
  orderId          String? @unique
  channel          String?
  grossAmount      Float
  commissionRate   Float
  commissionAmount Float
  netAmount        Float
  vatAmount        Float
  description      String
  recordedAt       BigInt
  recordedBy       String

  order Order? @relation(fields: [orderId], references: [orderId])

  @@index([source])
  @@index([channel])
}

model ExpenseRecord {
  id          String  @id @default(cuid())
  recordId    String  @unique
  category    String
  amount      Float
  vatAmount   Float
  description String
  date        BigInt
  receiptUrl  String?
  vendor      String?
  isRecurring Boolean @default(false)
  recordedAt  BigInt
  recordedBy  String

  @@index([category])
}

model MenuItem {
  id          String  @id @default(cuid())
  itemId      String  @unique
  name        String
  category    String
  unitPrice   Float
  costPrice   Float
  isAvailable Boolean @default(true)
  description String?

  @@index([category])
  @@index([isAvailable])
}
